CO-24\":\"Networking\",\"CO-23\":\"Graphics/sound/video\",\"CO-22\":\"Computer sciences in natural sciences\",\"CO-21\":\"Computer sciences in medicine and life sciences\",\"CO-20\":\"Computer sciences in the humanities\",\"CO-19\":\"Computer sciences in industry\",\"CO-18\":\"Computer sciences, other\",\"CO-17\":\"Bioinformatics\",\"CO-16\":\"Business computing\",\"CO-15\":\"Operating systems\",\"CO-14\":\"Computer sciences and media\",\"CO-12\":\"Databases and data mining\",\"CO-11\":\"IT-security and cryptology\",\"CO-10\":\"Software development\",\"CO-09\":\"Algorithms\",\"CO-08\":\"Programming and languages\",\"CO-07\":\"Computer architecture\",\"CO-06\":\"Project management\",\"CO-05\":\"Information technology\",\"CO-04\":\"Theoretical computer sciences\",\"CO-03\":\"Artificial intelligence\",\"CO-02\":\"History of computer sciences\",\"CO-01\":\"Fundamentals of computer sciences\",\"CO\":\"Computer sciences\",\"CL-05\":\"Classical studies, other\",\"CL-04\":\"Egyptology\",\"CL-03\":\"Byzantine studies\",\"CL-02\":\"Ancient Near Eastern studies\",\"CL-01-11\":\"Ancient philosophy\",\"CL-01-10\":\"Early Christianity\",\"CL-01-09\":\"Ancient religion\",\"CL-01-08\":\"Epigraphy\",\"CL-01-07\":\"Papyrology\",\"CL-01-06\":\"Classical tradition and reception\",\"CL-01-05\":\"Classical archaeology\",\"CL-01-04\":\"Ancient history\",\"CL-01-03\":\"Ancient science and medicine\",\"CL-01-02-02\":\"Latin language and literature\",\"CL-01-02-01\":\"Latin authors\",\"CL-01-02\":\"Latin\",\"CL-01-01-02\":\"Greek language and literature\",\"CL-01-01-01\":\"Greek authors\",\"CL-01-01\":\"Greek\",\"CL-01\":\"Classical studies\",\"CL\":\"Classical and Ancient Near Eastern studies\",\"CH-26\":\"Chemistry, other\",\"CH-25\":\"Toxicology\",\"CH-23\":\"Computational chemistry and molecular modeling\",\"CH-22\":\"Theoretical and quantum chemistry\",\"CH-20\":\"Spectroscopy\",\"CH-19\":\"Electrochemistry\",\"CH-17\":\"Physical chemistry\",\"CH-16\":\"Pharmaceutical and medicinal chemistry\",\"CH-15\":\"Macromolecular chemistry\",\"CH-14\":\"Catalysis\",\"CH-12\":\"Organic chemistry\",\"CH-11\":\"Nuclear chemistry\",\"CH-10\":\"Solid state chemistry\",\"CH-08\":\"Coordination chemistry\",\"CH-06\":\"Inorganic chemistry\",\"CH-05\":\"Sustainable and green chemistry\",\"CH-03\":\"Environmental chemistry\",\"CH-02\":\"Biochemistry\",\"CH-01\":\"Analytical chemistry\",\"CH\":\"Chemistry\",\"AR-12\":\"Antiques and collectibles\",\"AR-11-16\":\"Thuringia\",\"AR-11-15\":\"Schleswig-Holstein\",\"AR-11-14\":\"Saxony-Anhalt\",\"AR-11-13\":\"Saxony\",\"AR-11-12\":\"Saarland\",\"AR-11-11\":\"Rhineland-Palatinate\",\"AR-11-10\":\"North Rhine-Westphalia\",\"AR-11-09\":\"Mecklenburg-Vorpommern\",\"AR-11-08\":\"Lower Saxony\",\"AR-11-07\":\"Hesse\",\"AR-11-06\":\"Hamburg\",\"AR-11-05\":\"Bremen\",\"AR-11-04\":\"Brandenburg\",\"AR-11-03\":\"Berlin\",\"AR-11-02\":\"Bavaria\",\"AR-11-01\":\"Baden-Württemberg\",\"AR-11\":\"Art guides\",\"AR-10\":\"Conservation, preservation, restauration\",\"AR-09\":\"Dehio\",\"AR-08\":\"Exhibition catalogues\",\"AR-07\":\"History of art history\",\"AR-06\":\"Art market and provenance research\",\"AR-05\":\"Museums and collections\",\"AR-04-06\":\"21st century\",\"AR-04-05\":\"20th century\",\"AR-04-04\":\"19th century\",\"AR-04-03\":\"18th century\",\"AR-04-02\":\"16th-17th century\",\"AR-04-01\":\"8th-15th century\",\"AR-04\":\"Periods\",\"AR-03-06\":\"Genres, other\",\"AR-03-05\":\"Applied arts\",\"AR-03-04\":\"Graphic arts\",\"AR-03-03\":\"Photography\",\"AR-03-02\":\"Sculpture\",\"AR-03-01\":\"Painting\",\"AR-03\":\"Genres\",\"AR-02\":\"Art theory\",\"AR-01\":\"Arts, general\",\"AR\":\"Arts\",\"AD-04\":\"Architecture and design, other\",\"AD-03-04\":\"Studies, professional practice\",\"AD-03-03\":\"Graphics, communication\",\"AD-03-02\":\"Product design, interiors, materials\",\"AD-03-01\":\"Designers\",\"AD-03\":\"Design\",\"AD-02-04\":\"Studies, professional practice\",\"AD-02-03\":\"Construction, materials\",\"AD-02-02\":\"Gardens, landscapes\",\"AD-02-01\":\"Landscape architects\",\"AD-02\":\"Landscape architecture\",\"AD-01-10-03\":\"Conservation, preservation, restauration\",\"AD-01-10-02\":\"Dehio\",\"AD-01-10-01\":\"History, general\",\"AD-01-10\":\"History\",\"AD-01-09\":\"Theory\",\"AD-01-08\":\"Professional practice\",\"AD-01-07\":\"Studies\",\"AD-01-06\":\"Urbanism\",\"AD-01-05\":\"Cities, regions\",\"AD-01-04\":\"Types, functions\",\"AD-01-03\":\"Materials\",\"AD-01-02\":\"Construction\",\"AD-01-01\":\"Architects, buildings\",\"AD-01\":\"Architecture\",\"AD\":\"Architecture and design\",\"AS\":\"Asian and Pacific Studies\",\"AS-06\":\"East Asia\",\"AS-06-01\":\"China\",\"IC-09\":\"Analytical Chemistry\",\"IS\":\"Islamic and Middle Eastern Studies\",\"IS-01\":\"Introductions and Overviews\",\"IS-08\":\"Interreligious Studies\",\"IS-09\":\"History\",\"JMB\":\"Psychological methodology\",\"JMC\":\"Child, developmental and lifespan psychology\",\"KJSM\":\"Market research\",\"U\":\"Computing and Information Technology\",\"UNC\":\"Data capture and analysis\",\"UNF\":\"Data mining\",\"URD\":\"Privacy and data protection\",\"URH\":\"Computer fraud and hacking\",\"UTC\":\"Cloud computing\",\"UTN\":\"Network security\",\"UTP\":\"Networking standards and protocols\",\"UYQL\":\"Natural language and machine translation\",\"UYQN\":\"Neural networks and fuzzy systems\",\"UYQV\":\"Computer vision\"},\"series\":{\"series\":\"Series\"},\"cart\":{\"title\":\"Shopping cart\",\"empty\":\"Your cart is empty\",\"addToCart\":\"Add to cart\",\"inCart\":\"In Cart\",\"added\":\"Added!\",\"subscribe\":\"Subscribe\",\"remove\":\"Remove\",\"total\":\"Total\",\"checkout\":\"Proceed to checkout\",\"quantity\":\"Quantity\",\"item\":\"item\",\"items\":\"items\",\"success\":{\"title\":\"Payment Successful\",\"description\":\"Thank you for your purchase! Your payment has been completed.\",\"loading\":\"Processing your order...\",\"loadingDescription\":\"Please wait while we confirm your payment.\",\"invalidSession\":\"Invalid Session\",\"invalidSessionDescription\":\"This page can only be accessed after a successful payment.\",\"nextSteps\":{\"title\":\"What happens next?\",\"emailConfirmation\":{\"title\":\"Email confirmation\",\"description\":\"We'll send you an email shortly with your receipt and purchase details.\"},\"downloadAccess\":{\"title\":\"Download access\",\"description\":\"Your digital content is ready and can be downloaded anytime from your account.\"}},\"buttons\":{\"viewOrders\":\"View my orders\",\"continueShopping\":\"Continue shopping\",\"returnToCart\":\"Return to Cart\"}}},\"actions\":{\"download\":\"Download\",\"downloading\":\"Downloading\",\"preparing\":\"Preparing download\",\"downloadChapter\":\"Download chapter\",\"buyOnAmazon\":\"Buy on Amazon\",\"printAvailableAtAmazon\":\"Print: Available at Amazon\",\"buyPrint\":\"Buy print\",\"contactUs\":\"Contact us\",\"comingSoon\":\"Coming soon\",\"openAccess\":\"Open Access\",\"authorizedAccess\":\"Authorized access\",\"institutions\":\"Institutions\",\"print\":\"Print\",\"ebook\":\"E-Book\",\"chapter\":\"Chapter\"},\"cite\":{\"title\":\"Cite\",\"format\":\"Format\",\"copyToClipboard\":\"Copy to clipboard\",\"copied\":\"Copied\",\"downloadFormats\":\"Download formats\",\"risDescription\":\"ProCite RefWorks Reference Manager\",\"bibDescription\":\"BibTex Zotero\",\"endnoteDescription\":\"Endnote\"},\"about\":{\"hero\":{\"title\":\"your gateway to trusted knowledge\",\"description\":\"Reference-global.com is a comprehensive platform built for researchers, academics, professionals, and students to access resources quickly. Whether you're searching for the latest journal articles, looking for practical insights for your field, or curating materials for a library, reference-global.com brings it all together in one intuitive and easily accessible space.\"},\"features\":{\"access\":{\"title\":\"Access the content\",\"description\":\"Explore high-quality, relevant resources in one place: peer-reviewed journals, academic books from leading publishers, handbooks for practitioners, and global conference materials.\"},\"curate\":{\"title\":\"Curate and manage library resources\",\"description\":\"Discover, organize, and manage tailored materials for your institution with powerful tools that support smarter, more connected library ecosystems.\"},\"build\":{\"title\":\"Build your personal library\",\"description\":\"Create a customized space with your preferred titles, manage alerts for new content, and organize your own digital collection with ease.\"}},\"paradigm\":{\"title\":\"Brought to you by Paradigm Publishing Services\",\"description\":\"Reference-global.com is developed and managed by \u003cparadigm\u003eParadigm Publishing Services\u003c/paradigm\u003e, an innovative division of \u003cbrill\u003eDe Gruyter Brill\u003c/brill\u003e, with teams based in Boston, London, and Warsaw. Paradigm collaborates with independent publishers and scholarly presses, offering smart, flexible solutions that help partners remain globally visible, financially sustainable, and competitive in a fast-changing publishing landscape.\"},\"mission\":{\"title\":\"Shaped by a shared mission\",\"description\":\"Reference-global.com reflects Paradigm's commitment to building a more connected, accessible, and equitable future in scholarly communication. It offers a shared space for curated knowledge, bridging the gap between content creators and knowledge seekers across disciplines, industries, and borders.\"},\"cta\":{\"title\":\"Learn more about Paradigm Publishing Services\",\"button\":\"Visit Paradigm\"}},\"servicesForLibrarians\":{\"hero\":{\"title\":\"For librarians\",\"description\":\"Paradigm is transforming how academic libraries access, manage, and deliver scholarly content. By responding to the evolving needs of higher education, we offer a continuously expanding collection of high-quality publications from leading university presses and trusted academic and professional publishers.\",\"description2\":\"Our goal is to help libraries advance learning, teaching, and research by ensuring students, faculty, and scholars have reliable access to the resources they need—delivered through efficient, librarian-friendly systems.\"},\"buttons\":{\"primary\":\"View our partners\",\"secondary\":\"Partners on De Gruyter Brill\"},\"platform\":{\"title\":\"The reference-global.com platform\",\"description\":\"Developed with the needs of librarians at its core, reference-global.com combines robust functionality with intuitive design—empowering institutions to manage collections efficiently, integrate seamlessly with existing systems, and maximise discoverability.\"},\"features\":{\"management\":{\"title\":\"Effortless resource management\",\"description\":\"Our centralised librarian portal simplifies the oversight of subscriptions, licensing, and access permissions. With a comprehensive dashboard of usage statistics, libraries can streamline operations, reduce administrative burden, and optimise collection development.\"},\"metadata\":{\"title\":\"Enriched metadata for discoverability\",\"description\":\"We provide high-quality metadata, including MARC, ONIX, and KBART files, at no additional cost. This enables improved catalogue integration and ensures consistent, accurate discoverability across major discovery platforms.\"},\"integration\":{\"title\":\"Flexible integration\",\"description\":\"Reference-global.com supports a variety of acquisition models and works seamlessly with institutional systems—from authentication protocols to link resolvers—ensuring smooth implementation across library environments.\"},\"drm\":{\"title\":\"DRM-free, user-centered access\",\"description\":\"All subscription content is DRM-free, allowing users to download, print, and save materials for personal use—supporting both academic freedom and convenience.\"},\"discovery\":{\"title\":\"Discovery service compatibility\",\"description\":\"Reference-global.com is fully compatible with leading discovery and indexing platforms, helping users quickly locate and access content anytime, anywhere.\"}},\"guidance\":{\"text\":\"For guidance on using the librarian portal and downloading MARC and KBART files, visit the \u003clink\u003einstructions page\u003c/link\u003e.\"},\"cta\":{\"title\":\"Explore how we help libraries to better serve their communities\",\"button\":\"Visit Paradigm\"}},\"librarianManual\":{\"hero\":{\"title\":\"Librarian manual\",\"description\":\"Complete guide for librarians using the reference-global platform. This manual provides detailed instructions, best practices, and troubleshooting information to help you maximize your use of our services.\"},\"buttons\":{\"download\":\"Download manual (PDF)\",\"contactSupport\":\"Contact support\",\"viewFaq\":\"View FAQ\"},\"preview\":{\"title\":\"Manual preview\"}},\"servicesForPublishers\":{\"hero\":{\"title\":\"For publishers\",\"description\":\"At Paradigm, we deliver a comprehensive suite of services designed to empower academic publishers and editorial teams. Our support spans advanced technology, operational infrastructure, and strategic guidance, tailored to enhance every stage of the publishing process. All editorial authority, including decisions related to content creation, selection, and ownership, remains fully in the hands of our partners. Paradigm serves as a trusted ally, empowering our partners' work by providing the tools and expertise needed to navigate scholarly publishing with confidence and efficiency.\"},\"solutions\":{\"title\":\"Our solutions\",\"description\":\"Paradigm's services are modular, adaptable, and complementary, enabling each publishing partner to select the tailored support their publications require. Our services can be used together or selectively, ranging from content distribution to full-scale editorial production and visibility-enhancing marketing strategies.\",\"description2\":\"We support a full spectrum of publishing models, including diamond and gold open access with APC-based systems, subscription management, and Subscribe to Open initiatives. Publishers select the model or combination of services that align with their mission and financial strategy, while we deliver the infrastructure and expert support, ensuring effective implementation.\"},\"sections\":{\"technology\":{\"title\":\"Technology and production\",\"features\":{\"platform\":{\"title\":\"Content platform\",\"description\":\"We operate a proprietary content publishing and distribution platform that supports DOI registration, automated metadata creation, citation linking, and advanced search capabilities. Our technology is fully integrated with international scholarly infrastructure, including Crossref, indexing databases, and the ORCID system, and is built to meet the highest accessibility standards.\",\"description2\":\"For publishers seeking greater autonomy and control, we provide the option to design and implement a fully secure, independent content platform based on Open Journal Systems (OJS), customized to their specific editorial and operational needs.\"},\"editorial\":{\"title\":\"Editorial systems\",\"description\":\"Besides publishing technology, we offer a range of editorial software tailored by our specialists to fit each title's unique workflow. These include submission platforms, APC collection tools, plagiarism detection software, and research integrity solutions. For publishing partners that prefer OJS-based technology, we offer integrated submission and peer review solutions. Our team implements these systems while advising on process design and best practices to ensure seamless, efficient management.\"},\"services\":{\"title\":\"Editorial services\",\"description\":\"Editorial support encompasses language editing, copy-editing, and typesetting. These services guarantee readability, a professional presentation of content, and compliance with the academic publishing standards of published papers. In addition, we offer XML metadata and full-text formatting options that enhance visibility and compliance with indexing databases.\"}}},\"visibility\":{\"title\":\"Visibility and recognition\",\"features\":{\"indexing\":{\"title\":\"Indexing support\",\"description\":\"Comprehensive indexing assistance, including strategic guidance, is one of our greatest strengths and is a key service in our portfolio, consistently recognised and valued by our partners. We go beyond what a typical service provider offers. We do not just send metadata but also support editors in navigating complex submission and assessment processes, evaluating the readiness of their titles, guiding them through the requirements of various services, applying on their behalf, and ultimately delivering the content.\",\"description2\":\"Our indexing support is adaptable and customised to each title's requirements and scope, from basic metadata delivery to comprehensive evaluations, strategic consulting, and active involvement in the formal application process on behalf of the publisher.\",\"description3\":\"While we provide strategic guidance and technical support, all decisions regarding the implementation of indexing strategies remain entirely at the discretion of the publishers. We do not restrict independent applications submitted directly by our partners, should they choose to pursue that route.\",\"description4\":\"We are proud to support over 180 journals with CiteScore and more than 120 journals with an Impact Factor. The number of Paradigm-partnered journals indexed in Journal Citation Reports has more than tripled in recent years, reflecting the success of our collaborative approach.\"},\"marketing\":{\"title\":\"Marketing solutions\",\"description\":\"Our marketing services focus on visibility and academic impact. Our partners benefit from targeted email campaigns, outreach with custom-designed promotional materials, and social media engagement, increasing awareness, readership, and citations.\"},\"consulting\":{\"title\":\"Consulting services\",\"description\":\"Our experienced publishing advisors provide customised consulting to support publications at each stage of their development. These services include advice on editorial strategy, improving submission and peer review workflows, managing peer reviewers, and employing data-driven methods to enhance visibility and citation performance.\"}}},\"ownership\":{\"title\":\"Ownership and editorial independence\",\"features\":{\"rights\":{\"title\":\"Publisher rights\",\"description\":\"Titles we host, distribute, and provide services for remain the property of their publishers. This ownership is clearly reflected on each website, whether on reference-global.com or individual platforms built with the use of OJS software, where the publisher's logo and copyright statements are prominently displayed. Paradigm enters into formal service-level agreements that define roles and responsibilities, ensure licensing for content distribution, and protect the publisher's branding and intellectual property.\"},\"decisions\":{\"title\":\"Decision-making\",\"description\":\"Paradigm does not engage in editorial or policy decisions. Our role is to provide tools, guidance, and expert support, while full authority remains with the publishers and editorial boards. We serve as partners in the process - supportive, but never directive.\"},\"management\":{\"title\":\"Website content management\",\"description\":\"Publishing partners retain full control over how information related to their titles - such as aims and scope, editorial policies, submission guidelines, and contact details - is presented on the reference-global.com platform and individual OJS platforms. While Paradigm provides the technical infrastructure and offers expert advice, the decisions remain with the editorial teams. We periodically conduct site reviews to share best practices and updated requirements from indexing services, while fully respecting our partners' editorial independence.\"}}},\"support\":{\"title\":\"Day-to-day support\",\"description\":\"Each publication is assigned a dedicated customer service expert who provides consistent, hands-on support across all aspects of daily operations. From assistance with technical issues to advice on best practices, our specialists ensure that editorial teams receive prompt, practical support. They also act as the primary contact point between the editorial boards and our internal teams, promoting smooth communication and ensuring efficient service delivery.\"}},\"cta\":{\"title\":\"Ready to publish? Find the services and support you need\",\"button\":\"Contact us\"}},\"partner\":{\"title\":\"Interested in publishing with Paradigm?\",\"description\":\"Paradigm is your trusted partner in publishing and distributing books, journals, and proceedings. Join leading publishers.\",\"button\":\"Become a partner\"},\"share\":{\"title\":\"Share\",\"facebook\":\"Facebook\",\"x\":\"X (prev. Twitter)\",\"linkedin\":\"LinkedIn\",\"email\":\"Email\",\"copyLink\":\"Copy link\",\"copied\":\"Copied!\",\"shareVia\":\"Share via\"},\"publishingEthics\":{\"hero\":{\"title\":\"Publishing ethics\",\"description\":\"At Paradigm, we are committed to promoting responsible and transparent scholarly communication. We support publishers, authors, and editorial teams in upholding the highest standards of integrity across the research ecosystem. To foster fairness and accountability, we provide guidance aligned with industry best practices, offer strategic advice based on the evolving expectations of indexing services and the academic community, and regularly review platform settings on reference-global.com. Our approach is informed by internationally recognized frameworks, including the principles set forth by the Committee on Publication Ethics (COPE).\"},\"sections\":{\"whatWeOffer\":{\"title\":\"What we offer\",\"description\":\"Paradigm demonstrates its dedication to ethical publishing through comprehensive support across three main areas:\",\"features\":{\"guidance\":{\"title\":\"Guidance resources for journal editors\",\"description\":\"We maintain a dedicated and regularly updated collection of advisory materials covering topics such as authorship, peer review, corrections, and retractions. These resources are openly accessible through our platform and reflect the latest best practices in scholarly publishing.\"},\"tools\":{\"title\":\"Tools and infrastructure\",\"description\":\"Our modular services are designed to support ethical workflows at every stage of the publishing process—from initial submission to final publication. We provide a suite of adaptable tools, including submission management systems, plagiarism detection software, and research integrity solutions.\"},\"advisory\":{\"title\":\"Advisory support\",\"description\":\"For complex ethical questions, our experienced publishing specialists offer tailored guidance. While we do not mediate disputes or override editorial decisions, we help our partners navigate challenging situations by referencing international standards, identifying applicable policies, and suggesting clear, practical next steps. Our role is to build confidence and clarity—without compromising editorial autonomy.\"}}},\"editorialIndependence\":{\"title\":\"Editorial independence\",\"description\":\"Paradigm fully respects the autonomy of our publishing partners. All decisions related to content, editorial policy, and peer review rest solely with the publishers we support.\",\"description2\":\"We do not interfere in editorial matters or influence outcomes. Instead, we act as a collaborative partner—providing the tools, infrastructure, and expert support needed to uphold transparency, integrity, and independent decision-making across the publishing lifecycle.\"},\"sharedResponsibility\":{\"title\":\"Shared responsibility\",\"description\":\"In keeping with our values, Paradigm may suspend or discontinue collaboration if serious ethical breaches occur. This is not a punitive action, but a necessary measure to preserve mutual trust among authors, readers, and publishers and to safeguard the credibility of the scholarly record.\",\"description2\":\"We remain dedicated to fostering publishing environments where integrity, openness, and independence are not only safeguarded but also flourish.\"}}},\"register\":{\"messages\":{\"userAlreadyExists\":\"A user with the email address {email} has already registered an account. Please go to the log-in page. If you have forgotten your password, or have not yet created a password, you can use the 'Reset Password' link in the user menu.\",\"titleAccountCreated\":\"Thank you for registering on reference\u0026#8209;global.com\",\"accountCreated\":\"\u003cp\u003eAn activation email has been sent to {email}.\u003c/p\u003e\u003cp\u003ePlease follow the instructions in the message to activate your account and set your password.\u003c/p\u003e\",\"checkSpam\":\"If you don’t see the email in your inbox, please check your spam or junk folder.\",\"checkEmail\":\"Check your email\"}},\"contact\":{\"title\":\"Looking for answers?\",\"subtitle\":\"Still need assistance? We're happy to help - simply use one of the contact forms below.\",\"faqSubtitle\":\"Consult our FAQ page for quick help with common questions.\",\"faqButton\":\"View FAQ\",\"info\":{\"offices\":{\"boston\":{\"town\":\"Boston\",\"name\":\"Paradigm Publishing Services\\nDe Gruyter Brill, Inc.\",\"address\":\"121 High Street, 3rd Fl.\\nBoston, MA 02110\\nUnited States\",\"phone\":\"+1 857 214 2298\"},\"london\":{\"town\":\"London\",\"name\":\"Paradigm Publishing Services\\nUbiquity Press Ltd.\",\"address\":\"Unit 3N, 6 Osborn Street\\nLondon, E1 6TD\\nUnited Kingdom\",\"phone\":\"+44 (0) 207 323 0343\"},\"warsaw\":{\"town\":\"Warsaw\",\"name\":\"Paradigm Publishing Services\\nDe Gruyter Brill Sp. z o.o\",\"address\":\"Nowogrodzka 4/3\\n00-513 Warsaw\",\"phone\":\"+48 22 245 33 55\"}},\"email\":\"contact@pps.pub\",\"facebookURL\":\"https://www.facebook.com/sciendoglobal/\",\"linkedInURL\":\"https://www.linkedin.com/company/sciendo-publishing-services/\",\"blueSkyURL\":\"https://bsky.app/profile/reference-global.bsky.social\"},\"forms\":{\"labels\":{\"name\":\"Name and surname\",\"email\":\"Email\",\"country\":\"Country\",\"publicationType\":\"Publication type\",\"publicationTitle\":\"Publication title (journal / book / proceedings)\",\"publicationUrl\":\"Publication URL\",\"comments\":\"Comments\",\"inquiry\":\"Inquiry\",\"institution\":\"Institution\",\"phone\":\"Phone number\",\"send\":\"Send\",\"clear\":\"Clear\",\"successMessageTitle\":\"Message sent successfully\",\"successMessageBody\":\"Thank you for contacting us.\u003cbr/\u003eWe’ve received your message and will get back to you shortly.\",\"errorMessageTitle\":\"Error sending message\",\"errorMessageBody\":\"Please contact us directly at \u003cemailUrl\u003e{email}\u003c/emailUrl\u003e - our team will be happy to assist you.\"},\"fieldOptions\":{\"publicationTypes\":{\"journal\":\"Journal\",\"conference\":\"Conference Proceedings\",\"book\":\"Book\",\"other\":\"Other\"},\"inquiry\":{\"journal\":\"Journal services\",\"book\":\"Book services\",\"conference\":\"Conference services\",\"whiteLabel\":\"White Label Publishing House\",\"other\":\"Other inquiries\"}},\"authors\":{\"title\":\"I am an author\",\"subtitle\":\"I would like to enquire about my manuscript\"},\"editors\":{\"title\":\"I am an editor\",\"subtitle\":\"I would like to publish a journal or conference proceedings\"},\"librarians\":{\"title\":\"I am a librarian\",\"subtitle\":\"I am seeking information about content access for my library\"},\"inquiry\":{\"title\":\"General inquiry\",\"subtitle\":\"I have a different question or would like to reach support\"}}},\"librarian\":{\"root\":{\"urlKey\":\"librarian\",\"label\":\"Librarian\"},\"tabs\":{\"holdings\":{\"urlKey\":\"holdings\",\"label\":\"Holdings\"},\"usage\":{\"urlKey\":\"usage\",\"label\":\"Usage\"},\"update-ips\":{\"urlKey\":\"update-ips\",\"label\":\"Update IPs\",\"title\":\"Self-service editing and updating of your IP addresses\",\"body\":\"\u003cp\u003eWe partner with \u003cb\u003eThe IP Registry\u003c/b\u003e to simplify the process of checking, updating, and managing IP addresses used to authenticate access to content—making it easier for librarians to ensure seamless access.\u003c/p\u003e\u003cp\u003eThe IP Registry is a centralized, trusted database of more than 1.5 billion verified IP addresses from over 60,000 content licensing organizations worldwide. It is maintained for the benefit of the global scholarly communication community and is accessible to both publishers and libraries.\u003c/p\u003e\u003cp\u003eWith the IP Registry, a service by PSI, publishers and libraries can save time, reduce administrative workload, minimize errors, improve the accuracy of usage metrics, and ensure that the right users have access to the right content.\u003c/p\u003e\",\"sidebarBody\":\"\u003cIf\u003eTo update or manage your IP addresses, please log in using the link below. If you don’t have an account, you can register directly on the login page.\u003c/p\u003e\",\"buttonText\":\"Login to PSI\",\"buttonURL\":\"https://www.psiregistry.org/\"}},\"labels\":{\"contentLicencedBy\":\"Content licenced by:\",\"viewUsageFor\":\"View usage for:\",\"noEntitlements\":\"Currently there are no {type} licenced by {institution}\",\"noAccess\":\"\u003cp\u003eYou do not have access to the selected account, or the link you followed is no longer valid.\u003c/p\u003e\u003cp\u003ePlease double-check the link, return to the homepage, or log in again.\u003c/p\u003e\u003cp\u003eIf you believe this is an error, feel free to contact our support team for assistance.\u003c/p\u003e\"},\"institutionSelector\":{\"invalid\":\"Invalid account\",\"emptyList\":\"No available accounts\"},\"downloadButton\":{\"exportAll\":\"Export all holdings\",\"export\":\"Export\",\"exportAs\":\"Download as {extension}\"},\"tables\":{\"