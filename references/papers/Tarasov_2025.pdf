"$\",\"div\",null,{\"className\":\"max-w-[77.5rem] mx-auto grid grid-cols-1 md:grid-cols-[auto_1fr] xl:grid-cols-[auto_1fr_auto] gap-6 xl:gap-8 items-start\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex justify-center md:justify-start\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-[15.625rem] data-[white-background=true]:bg-white flex justify-center items-stretch relative h-[280px]\",\"children\":[[[\"$\",\"$L7c\",null,{\"image\":{\"blurHash\":\"$72:props:product:covers:0:blurHash\",\"aspectRatio\":\"$72:props:product:covers:0:aspectRatio\",\"urls\":\"$72:props:product:covers:0:urls\"},\"alt\":\"Algorithm-Driven Hedonic Real Estate Pricing – An Explainable AI Approach Cover\",\"className\":\"!relative object-contain transition-transform duration-200 rounded-lg !w-auto !h-auto !max-h-full rounded-lg\",\"style\":{\"objectFit\":\"contain\"},\"initialSrc\":\"$7d\"}],\"$L7e\"],\"$L7f\"]}]}],\"$L80\",\"$L81\",\"$L82\"]}]}]}]\n"])</script><script>self.__next_f.push([1,"84:T48d,"])</script><script>self.__next_f.push([1,"Data-driven machine learning algorithms triggered a fundamental change in hedonic real estate pricing. However, their adaptive nonparametric structure makes inference and out-ofsample prediction challenging. This study introduces an explainable approach to interpreting machine learning predictions, which has not been done before in the local market context. Specifically, Random Forest and Extreme Gradient Boosting models are developed for residential real estate price prediction in Warsaw in 2021 on 10,827 property transactions. Model-agnostic Explainable Artificial Intelligence (XAI) methods are then used to investigate the black box decision making. The results show the practicability of applying XAI frameworks in the real estate market context to decode the rationale behind data-driven algorithms. Information about the relationships between input variables is extracted in greater detail. Accurate, reliable and transparent real estate valuation support tools can offer substantial advantages to participants in the real estate market, including banks, insurers, pension and sovereign wealth funds, as well public authorities and private individuals."])</script><script>self.__next_f.push([1,"79:[\"$\",\"div\",null,{\"className\":\"bg-white w-full\",\"children\":[\"$\",\"div\",null,{\"className\":\"w-full text-black00 flex justify-stretch items-center\",\"role\":\"region\",\"children\":[\"$\",\"div\",null,{\"className\":\"m-auto w-full flex flex-col items-stretch justify-center data-[fluid=true]:max-w-full data-[fluid=false]:max-w-[1280px] px-5 py-8 md:py-12\",\"data-fluid\":false,\"children\":[\"$\",\"$L83\",null,{\"product\":\"$72:props:product\",\"tabs\":[{\"id\":\"abstract\",\"available\":true},{\"id\":\"preview\",\"available\":true,\"clientOnly\":true},{\"id\":\"download\",\"available\":true},{\"id\":\"references\",\"available\":true},{\"id\":\"authors\",\"available\":true},{\"id\":\"metrics\",\"available\":true},{\"id\":\"articles-in-this-issue\",\"available\":true,\"clientOnly\":true}],\"initialActiveTab\":\"abstract\",\"initialTabContent\":[[[\"$\",\"h2\",null,{\"className\":\"text-subtitle-l font-medium text-black00 mb-3\",\"children\":\"Abstract\"}],[\"$\",\"div\",null,{\"className\":\"text-body-m text-neutral-20 wp-content html-content\",\"children\":[\"$\",\"div\",null,{\"className\":\"abstract-content\",\"children\":[\"$\",\"div\",null,{\"xmlns\":\"http://www.w3.org/1999/xhtml\",\"data-abstract\":\"true\",\"children\":[\"\\n\\n\",[\"$\",\"p\",\"1\",{\"children\":\"$84\"}],\"\\n\"]}]}]}]],[\"$\",\"noscript\",null,{\"children\":[\"$\",\"div\",null,{\"className\":\"w-full h-full\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"text-subtitle-l font-medium text-black00 mb-6\",\"children\":\"References\"}],[\"$\",\"div\",null,{\"className\":\"text-body-m text-neutral-20 wrap-anywhere\",\"children\":[\"$\",\"ol\",null,{\"className\":\"list-decimal list-inside space-y-4\",\"children\":[[\"$\",